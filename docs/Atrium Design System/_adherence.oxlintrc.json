{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/social/**",
              "components/core/**",
              "deck/**",
              "ui_kits/atrium-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nimora|Inter Tight|Instrument Serif|Nothing You Could Do))/i]",
        "message": "Font not provided by the design system. Available: Nimora, Inter Tight, Instrument Serif, Nothing You Could Do."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:mint|teal|amber|cloud|outline)$/]",
        "message": "<Badge> tone must be one of 'mint' | 'teal' | 'amber' | 'cloud' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|iconLeft|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, iconLeft, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|mint|amber|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'mint' | 'amber' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|padding|radius|bordered|hover|elevation|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, padding, radius, bordered, hover, elevation, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|cloud|mint|amber|teal|aurora|aurora-mint|aurora-amber)$/]",
        "message": "<Card> tone must be one of 'light' | 'cloud' | 'mint' | 'amber' | 'teal' | 'aurora' | 'aurora-mint' | 'aurora-amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:none|soft|float)$/]",
        "message": "<Card> elevation must be one of 'none' | 'soft' | 'float'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|selected|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, variant, selected, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|outline-light|outline-soft|mint|mint-soft|teal|ink|amber)$/]",
        "message": "<Chip> variant must be one of 'outline' | 'outline-light' | 'outline-soft' | 'mint' | 'mint-soft' | 'teal' | 'ink' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Chip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|spread|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, spread, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|teal|mint|amber|onDark)$/]",
        "message": "<Eyebrow> tone must be one of 'muted' | 'teal' | 'mint' | 'amber' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='spread'] > Literal[value!=/^(?:wide|widest)$/]",
        "message": "<Eyebrow> spread must be one of 'wide' | 'widest'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|style|key|ref|className|style|children)$/]",
        "message": "<Highlight> doesn't accept that prop. Declared props: children, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:amber|mint|teal)$/]",
        "message": "<Highlight> color must be one of 'amber' | 'mint' | 'teal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|invalid|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, invalid, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|color|height|assetBase|gap|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, color, height, assetBase, gap, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:mark|wordmark|lockup)$/]",
        "message": "<Logo> variant must be one of 'mark' | 'wordmark' | 'lockup'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScriptAccent'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|underline|color|style|key|ref|className|style|children)$/]",
        "message": "<ScriptAccent> doesn't accept that prop. Declared props: children, underline, color, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
