
# Cloudinary (launch-phase asset delivery). Get from Cloudinary dashboard.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Canonical production URL — used for metadataBase, sitemap.ts, robots.ts,
# and absolute OG/Twitter image URLs. Must also be set in the Vercel
# project's environment variables for production builds.
NEXT_PUBLIC_SITE_URL=https://www.atriumad.com
